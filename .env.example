# Database (docker-compose uses pgvector/pgvector:pg17 for vector search)
DATABASE_URL=postgres://memory:memory_dev_pass@localhost:5432/ai_team_memory

# Server
PORT=3000
# API_PUBLIC_URL=https://your-domain.com

# LLM Provider: openai | openrouter | mindflow
LLM_PROVIDER=openrouter

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_EXTRACT_MODEL=openai/gpt-4.1-mini
OPENROUTER_EMBED_MODEL=openai/text-embedding-3-small
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=
# OPENROUTER_X_TITLE=

# OpenAI (if LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_EXTRACT_MODEL=gpt-4.1-mini
# OPENAI_EMBED_MODEL=text-embedding-3-small
# OPENAI_BASE_URL=

# Mindflow (if LLM_PROVIDER=mindflow)
# MINDFLOW_API_KEY=
# MINDFLOW_BASE_URL=
# MINDFLOW_EXTRACT_MODEL=gpt-4.1-mini
# MINDFLOW_EMBED_MODEL=text-embedding-3-small

# GitHub
GITHUB_TOKEN=ghp_your_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Slack Bot (optional — leave blank to disable)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your_signing_secret

# OAuth (for user-facing "Connect" flows)
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
SLACK_CLIENT_ID=your_slack_app_client_id
SLACK_CLIENT_SECRET=your_slack_app_client_secret

# Security
ENCRYPTION_KEY=generate_64_hex_chars_for_token_encryption
DASHBOARD_URL=http://localhost:3001

# Authentication (set to "true" for production)
AUTH_REQUIRED=false

# Rate limiting (requests per minute per API key)
RATE_LIMIT_PER_MINUTE=60
